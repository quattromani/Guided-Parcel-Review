{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guided-parcel-review.local/schemas/property-manifest.schema.json",
  "title": "Guided Parcel Review Manifest",
  "type": "object",
  "required": ["version", "activePropertyId", "properties", "sharedData"],
  "properties": {
    "version": { "type": "string" },
    "metadata": { "type": "object" },
    "activePropertyId": { "type": ["string", "null"] },
    "properties": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "county", "recordCardPath"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "propertyClass": { "type": "string" },
          "parcelId": { "type": "string" },
          "situsAddress": { "type": "string" },
          "county": { "type": "string" },
          "taxDistrict": { "type": "string" },
          "recordCardPath": { "type": "string" },
          "recordCardStatus": { "type": "string" },
          "sampleVisibility": {
            "type": "string",
            "enum": ["public", "research"],
            "description": "Controls whether the property appears in the public sample switcher. Omitted values are treated as public by the app."
          }
        }
      }
    },
    "sharedData": {
      "type": "object",
      "required": ["calendarPath", "realPropertyFormsPath", "statewideCtlPath", "counties", "standards"],
      "properties": {
        "calendarPath": { "type": "string" },
        "legalReferencesPath": { "type": "string" },
        "realPropertyFormsPath": { "type": "string" },
        "statewideCtlPath": { "type": "string" },
        "counties": { "type": "object" },
        "standards": { "type": "object" }
      }
    }
  }
}
