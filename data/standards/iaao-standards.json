{
  "metadata": {
    "title": "IAAO Assessment Standards",
    "source": {
      "sourceType": "standard",
      "displayCitation": "2025 IAAO Standard on Ratio Studies",
      "notes": "Standards and definitions are used for ratio-study interpretation in the assessment-ratio views. COV ranges are derived from IAAO guidance that COV is approximately 1.25 times COD in a normal distribution."
    },
    "version": "2026-reference",
    "notes": [
      "COV is approximately 1.25 times the COD in a normal distribution.",
      "PRD above 1.03 tends to indicate regressivity.",
      "PRD below 0.98 tends to indicate progressivity."
    ]
  },
