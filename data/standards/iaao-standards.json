{
  "metadata": {
    "title": "IAAO Assessment Standards",
    "source": "IAAO Standards referenced in 2026 Gage County R&O",
    "version": "2026-reference",
    "notes": [
      "COV is approximately 1.25 times the COD in a normal distribution.",
      "PRD above 1.03 tends to indicate regressivity.",
      "PRD below 0.98 tends to indicate progressivity."
    ]
  },
  "prdStandards": {
    "acceptableRange": {
      "min": 0.98,
      "max": 1.03
    },
    "interpretation": {
      "belowRange": "Assessment progressivity",
      "withinRange": "Acceptable vertical equity",
      "aboveRange": "Assessment regressivity"
    },
    "definition": "Price-related differential is a statistical measure of vertical property tax equity calculated by dividing the mean ratio by the weighted mean ratio."
  },
  "covGuidance": {
    "formula": "COV ≈ COD × 1.25",
    "definition": "In a normal distribution, the coefficient of variation is approximately 1.25 times the coefficient of dispersion.",
    "note": "This is a derived approximation and not a direct IAAO threshold standard."
  },
