  "sampleSizeGuidance": {
    "qualifiedSales": {
      "sourceLabel": "Property Snapshot qualified-sales sample signal",
      "direction": "sampleSize",
      "thresholds": [
        {
          "min": 500,
          "minShare": 0.75,
          "tone": "green",
          "severity": "useful",
          "label": "Broad sample",
          "trigger": "large share of countywide qualified sales",
          "explanation": "The sales sample is broad enough to provide useful context for this comparison."
        },
        {
          "min": 100,
          "minShare": 0.25,
          "tone": "yellowGreen",
          "severity": "context",
          "label": "Usable sample",
          "trigger": "usable share of countywide qualified sales",
          "explanation": "Enough qualified sales are available to provide useful context for this comparison."
        },
        {
          "min": 50,
          "tone": "yellow",
          "severity": "context",
          "label": "Limited sample",
          "trigger": "modest number of qualified sales",
          "explanation": "The sales sample can help with context, but it should be read carefully."
        },
        {
          "min": 10,
          "tone": "orange",
          "severity": "caution",
          "label": "Thin sample",
          "trigger": "small number of qualified sales",
          "explanation": "The sales sample is thin, so this comparison may be less reliable."
        },
        {
          "max": 9,
          "tone": "red",
          "severity": "alarm",
          "label": "Very thin sample",
          "trigger": "fewer than 10 qualified sales",
          "explanation": "The sales sample is too thin to support a confident comparison by itself."
        }
      ]
    }
  },
  "prdStandards": {
    "key": "iaao-prd-98-103",
    "sourceLabel": "IAAO PRD 98-103",
    "acceptableRange": {
      "min": 0.98,
      "max": 1.03
    },
    "interpretation": {
      "belowRange": "Assessment progressivity",
      "withinRange": "Acceptable vertical equity",
      "aboveRange": "Assessment regressivity"
    },
    "definition": "Price-related differential is a statistical measure of vertical property tax equity calculated by dividing the mean ratio by the weighted mean ratio."
  },
  "covGuidance": {
    "formula": "COV ≈ COD × 1.25",
    "definition": "In a normal distribution, the coefficient of variation is approximately 1.25 times the coefficient of dispersion.",
    "note": "This is a derived approximation and not a direct IAAO threshold standard."
  },
